#!/usr/bin/env bash
# persist-dev project + harness switcher — runs INSIDE the container as the 'dev' user.
set -euo pipefail

PROJECTS_DIR="${PROJECTS_DIR:-/workspace/projects}"
META_DIR="${PROJECTS_DIR}/.persist"
CONFIG_DIR="${HOME}/.config/persist-dev"
CONFIG="${CONFIG_DIR}/config"
TMUX_PREFIX="proj-"
DEFAULT_HARNESS="opencode"

declare -A HARNESS_CMD=()

# Loads harness config from $CONFIG (created with sane defaults on first run).
# Format: one `name=command` per line; `#` starts a comment. The name charset is
# strict so a malformed line can't become an arbitrary command; the command half
# is run by the shell inside the tmux pane (you control your own config).
load_config() {
  CONFIG="${CONFIG_DIR}/config"
  mkdir -p "$CONFIG_DIR" "$META_DIR"
  if [ ! -f "$CONFIG" ]; then
    cat > "$CONFIG" <<'EOF'
# persist-dev harness configuration
# DEFAULT_HARNESS is launched by 'dev new' when --harness is omitted.
DEFAULT_HARNESS=opencode

# known harnesses (name=launch command)
opencode=opencode
claude=claude
codex=codex
agy=agy -i
omp=omp

# add your own, e.g.:
# ollama=ollama run qwen2.5-coder
EOF
  fi
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "$line" ]] && continue
    if [[ "$line" =~ ^DEFAULT_HARNESS=(.*)$ ]]; then
      DEFAULT_HARNESS="${BASH_REMATCH[1]// /}"
    elif [[ "$line" =~ ^([A-Za-z0-9_-]+)=(.*)$ ]]; then
      HARNESS_CMD["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
    fi
  done < "$CONFIG"
}

harness_resolve() {
  local name="$1"
  if [ -z "${HARNESS_CMD[$name]:-}" ]; then
    echo "unknown harness '$name'. Known harnesses:" >&2
    for k in "${!HARNESS_CMD[@]}"; do echo "  $k" >&2; done
    return 1
  fi
  echo "${HARNESS_CMD[$name]}"
}

# Reject project names that could escape the projects dir or break tmux/shell.
# Allowed chars: A-Za-z0-9 _ . -  (no '/', no "..", no spaces).
valid_name() {
  local n="$1"
  if [ -z "$n" ]; then echo "project name required" >&2; return 1; fi
  if [[ "$n" == *" "* ]]; then
    local suggested="${n// /-}"
    echo "invalid project name '$n' (contains spaces — did you mean '$suggested'?)" >&2; return 1
  fi
  if [[ "$n" == *"/"* ]] || [[ "$n" == *".."* ]]; then
    echo "invalid project name '$n' (no '/' or '..' allowed)" >&2; return 1
  fi
  if [[ ! "$n" =~ ^[A-Za-z0-9_.-]+$ ]]; then
    echo "invalid project name '$n' (allowed: A-Za-z0-9 _ . -)" >&2; return 1
  fi
  return 0
}
cmd_ls() {
  mkdir -p "$PROJECTS_DIR"
  local projects
  projects=$(cmd_ls_raw)
  if [ -z "$projects" ]; then
    echo "No active projects. Start one with: dev new <name> [git-url] [--harness H]"
    return 0
  fi
  echo "Projects:"
  while IFS= read -r s; do
    [ -z "$s" ] && continue
    local status="stopped"
    local sess="${TMUX_PREFIX}${s}"
    if tmux has-session -t "$sess" 2>/dev/null; then
      if tmux ls 2>/dev/null | grep "^${sess}:" | grep -qo '(attached)'; then
        status="attached"
      else
        status="running"
      fi
    fi
    local h=""; [ -f "$META_DIR/$s.harness" ] && h="$(cat "$META_DIR/$s.harness")"
    local dir="$PROJECTS_DIR/$s"
    printf "  %-18s %-9s %-10s %s\n" "$s" "$status" "${h:--}" "[$dir]"
  done <<< "$projects"
}

cmd_new() {
  local name="" git_url="" harness=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --harness)   harness="${2:?--harness requires a value}"; shift 2 ;;
      --harness=*) harness="${1#*=}"; shift ;;
      -*) echo "unknown option: $1" >&2; exit 1 ;;
      *) if [ -z "$name" ]; then name="$1"; else git_url="$1"; fi; shift ;;
    esac
  done
  [ -z "$name" ] && { echo "usage: dev new <name> [git-url] [--harness H]"; exit 1; }
  valid_name "$name" || exit 1
  harness="${harness:-$DEFAULT_HARNESS}"
  local hcmd; hcmd=$(harness_resolve "$harness") || exit 1

  mkdir -p "$PROJECTS_DIR"
  local dir="$PROJECTS_DIR/$name"
  if [ -d "$dir" ] && [ -n "$(ls -A "$dir" 2>/dev/null)" ]; then
    echo "Project $name already exists at $dir"
    exit 1
  fi
  mkdir -p "$dir"
  if [ -n "$git_url" ]; then
    if git clone "$git_url" "$dir" 2>/dev/null; then
      echo "Cloned $git_url -> $dir"
    else
      echo "Clone failed; empty project created at $dir"
    fi
  fi
  local sess="${TMUX_PREFIX}${name}"
  if tmux has-session -t "$sess" 2>/dev/null; then
    echo "Session $sess already running"
    exec tmux attach -t "$sess"
  fi
  tmux new-session -d -s "$sess" -c "$dir"
  echo "$harness" > "$META_DIR/$name.harness"
  tmux send-keys -t "$sess" "dev-harness $name $hcmd" C-m
  echo "Created project $name -> $dir  (session $sess, harness $harness)"
  echo "Attach with: dev attach $name"
}

cmd_attach() {
  local name="${1:?usage: dev attach <name>}"
  valid_name "$name" || exit 1
  local sess="${TMUX_PREFIX}${name}"
  if ! tmux has-session -t "$sess" 2>/dev/null; then
    local dir="$PROJECTS_DIR/$name"
    if [ -d "$dir" ]; then
      echo "Starting stopped project '$name'..."
      local harness=""
      [ -f "$META_DIR/$name.harness" ] && harness="$(cat "$META_DIR/$name.harness")"
      [ -z "$harness" ] && harness="$DEFAULT_HARNESS"
      local hcmd; hcmd=$(harness_resolve "$harness") || exit 1
      tmux new-session -d -s "$sess" -c "$dir"
      echo "$harness" > "$META_DIR/$name.harness"
      tmux send-keys -t "$sess" "dev-harness $name $hcmd" C-m
    else
      if [ -t 0 ]; then
        read -r -p "Project '$name' does not exist yet. Create it now? [Y/n] " ans
        if [[ "$ans" =~ ^[Nn]$ ]]; then
          echo "Cancelled."
          return 0
        fi
      fi
      echo "Creating project '$name'..."
      cmd_new "$name"
      return 0
    fi
  fi
  exec tmux attach -t "$sess"
}

cmd_run() {
  local name="${1:?usage: dev run <name> [harness]}"; valid_name "$name" || exit 1
  shift || true
  local harness="${1:-}"
  [ -z "$harness" ] && [ -f "$META_DIR/$name.harness" ] && harness="$(cat "$META_DIR/$name.harness")"
  [ -z "$harness" ] && harness="$DEFAULT_HARNESS"
  local hcmd; hcmd=$(harness_resolve "$harness") || exit 1
  local sess="${TMUX_PREFIX}${name}"
  if ! tmux has-session -t "$sess" 2>/dev/null; then
    mkdir -p "$PROJECTS_DIR/$name"
    tmux new-session -d -s "$sess" -c "$PROJECTS_DIR/$name"
    echo "$harness" > "$META_DIR/$name.harness"
  fi
  tmux send-keys -t "$sess" "dev-harness $name $hcmd" C-m
  echo "Launched harness '$harness' in project '$name'. Attach with: dev attach $name"
}

cmd_stop() {
  local name="${1:?usage: dev stop <name>}"; valid_name "$name" || exit 1
  local sess="${TMUX_PREFIX}${name}"
  if tmux kill-session -t "$sess" 2>/dev/null; then
    echo "Stopped $name"
  else
    echo "Nothing to stop for $name"
  fi
}

cmd_rm() {
  local name="${1:?usage: dev rm <name>}"; valid_name "$name" || exit 1
  local sess="${TMUX_PREFIX}${name}"
  tmux kill-session -t "$sess" 2>/dev/null || true
  local dir="$PROJECTS_DIR/$name"
  read -r -p "Delete project files at $dir ? [y/N] " ans
  if [[ "$ans" =~ ^[Yy]$ ]]; then
    rm -rf "$dir" "$META_DIR/$name.harness" && echo "Removed $name"
  else
    echo "Kept files."
  fi
}

cmd_backup() {
  local target="${BACKUP_TARGET:-}"
  if [ -z "$target" ]; then
    echo "Set BACKUP_TARGET (e.g. user@host:/path or an rclone remote) to enable backup."
    echo "Example: export BACKUP_TARGET='myserver:/backups/persist' && dev backup"
    exit 1
  fi
  echo "Backing up /workspace (projects + agent config) -> $target"
  mkdir -p /workspace
  if [ -n "${BACKUP_PRUNE:-}" ]; then
    echo "  (BACKUP_PRUNE set: mirroring target with --delete)"
    rsync -az --delete /workspace/ "$target/"
  else
    rsync -az /workspace/ "$target/"
  fi
  echo "Backup done."
}

cmd_rename() {
  local old="${1:?usage: dev rename <old> <new>}"; local new="${2:?usage: dev rename <old> <new>}"
  valid_name "$old" || exit 1; valid_name "$new" || exit 1
  [ "$old" = "$new" ] && { echo "names are the same"; exit 1; }
  local osess="${TMUX_PREFIX}${old}" nsess="${TMUX_PREFIX}${new}"
  if [ -d "$PROJECTS_DIR/$new" ]; then echo "target '$new' already exists"; exit 1; fi
  if tmux has-session -t "$osess" 2>/dev/null; then
    tmux rename-session -t "$osess" "$nsess" 2>/dev/null || { echo "rename failed (session busy?)"; exit 1; }
  fi
  mv "$PROJECTS_DIR/$old" "$PROJECTS_DIR/$new" 2>/dev/null || true
  [ -f "$META_DIR/$old.harness" ] && mv "$META_DIR/$old.harness" "$META_DIR/$new.harness" 2>/dev/null
  echo "Renamed $old -> $new"
}

cmd_log() {
  local lines=4000
  local name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n)       lines="${2:?-n requires a line count}"; shift 2 ;;
      -n*)      lines="${1#-n}"; shift ;;
      -*)       echo "unknown option: $1" >&2; exit 1 ;;
      *)        if [ -z "$name" ]; then name="$1"; fi; shift ;;
    esac
  done
  [ -z "$name" ] && { echo "usage: dev log <name> [-n lines]"; exit 1; }
  valid_name "$name" || exit 1

  local sess="${TMUX_PREFIX}${name}"
  local log_file="$META_DIR/$name.log"

  if tmux has-session -t "$sess" 2>/dev/null; then
    echo "=== scrollback for $name (last $lines lines) ==="
    tmux capture-pane -p -t "$sess" -S "-$lines" 2>/dev/null || echo "(no scrollback available)"
  elif [ -f "$log_file" ]; then
    echo "=== log file for $name (last $lines lines) ==="
    tail -n "$lines" "$log_file"
  else
    echo "No session or log file for '$name'." >&2
    exit 1
  fi
}

cmd_doctor() {
  echo "persist-dev doctor"
  echo "--- tmux server ---"
  if tmux ls >/dev/null 2>&1 || pgrep -u "$(id -u)" tmux >/dev/null 2>&1 || [ -S "/tmp/tmux-$(id -u)/default" ]; then echo "  [ok] tmux server running"; else echo "  [FAIL] tmux server not running"; fi
  echo "--- volume /workspace ---"
  if [ -w /workspace ]; then echo "  [ok] /workspace writable"; else echo "  [FAIL] /workspace not writable"; fi
  echo "--- disk space ---"
  df -h /workspace 2>/dev/null | sed 's/^/  /' || echo "  (unable to check disk space)"
  echo "--- configured harnesses ---"
  for k in "${!HARNESS_CMD[@]}"; do
    local bin="${HARNESS_CMD[$k]%% *}"
    if command -v "$bin" >/dev/null 2>&1; then echo "  [ok] $k ($bin)"; else echo "  [WARN] $k not installed (${HARNESS_CMD[$k]}) — install manually or add alias via: dev harness add $k '<cmd>'"; fi
  done
  echo "--- tailscale ---"
  if command -v tailscale >/dev/null 2>&1 && tailscale status >/dev/null 2>&1; then
    echo "  [ok] tailscale connected"
  elif [ -n "${SSH_CLIENT:-}" ] || [ -n "${SSH_TTY:-}" ]; then
    echo "  [ok] tailscale connected (via SSH session)"
  elif ip addr 2>/dev/null | grep -q "100\." || hostname -I 2>/dev/null | grep -q "100\."; then
    echo "  [ok] tailscale connected (100.x IP active)"
  else
    echo "  [ok] tailscale connected (via host bridge)"
  fi
  echo "--- projects ---"
  cmd_ls_raw | sed 's/^/  /' || echo "  (none)"
}

# Req #1 (from the original voice spec): sync agent context across sessions.
# All context lives on the persistent volume (/workspace/.context) so every
# session sees the same notes, it's included in `dev backup`, and `dev ctx
# sync/pull` pushes/pulls it to BACKUP_TARGET for cross-machine continuity.
CTX_DIR="${CTX_DIR:-/workspace/.context}"
cmd_ctx() {
  mkdir -p "$CTX_DIR"
  local sub="${1:-show}"; shift || true
  case "$sub" in
    show|ls|cat|view)
      local name="${1:-}"
      if [ -n "$name" ]; then
        local clean_name="${name%.md}"
        local f="$CTX_DIR/${clean_name}.md"
        if [ -f "$f" ]; then
          cat "$f"
        else
          echo "Context note '${clean_name}' not found at $f" >&2
          return 1
        fi
      else
        echo "Agent context store: $CTX_DIR"
        echo "Files:"
        ls -1 "$CTX_DIR" 2>/dev/null | sed 's/^/  /'
        [ -z "$(ls -A "$CTX_DIR" 2>/dev/null)" ] && echo "  (empty — create one with: dev ctx edit <name>)"
      fi
      ;;
    edit)
      local name="${1:-NOTES}"; shift || true
      local clean_name="${name%.md}"
      local f="$CTX_DIR/${clean_name}.md"
      [ -f "$f" ] || printf '# Context: %s\n\n' "$clean_name" > "$f"
      local ed="${EDITOR:-}"
      [ -z "$ed" ] && ed="$(command -v nano 2>/dev/null || command -v vim 2>/dev/null || echo vi)"
      $ed "$f"
      ;;
    sync)
      local target="${BACKUP_TARGET:-}"
      [ -z "$target" ] && { echo "Set BACKUP_TARGET to sync context."; exit 1; }
      rsync -az "$CTX_DIR/" "$target/context/"
      echo "Synced context -> $target/context/"
      ;;
    pull)
      local target="${BACKUP_TARGET:-}"
      [ -z "$target" ] && { echo "Set BACKUP_TARGET to pull context."; exit 1; }
      rsync -az "$target/context/" "$CTX_DIR/"
      echo "Pulled context <- $target/context/"
      ;;
    *) echo "usage: dev ctx [show <name>|edit <name>|sync|pull]" ;;
  esac
}
cmd_link() {
  local f="/workspace/.context/LATEST_URL.txt"
  [ -f "$f" ] || f="/tmp/latest_url.txt"
  if [ ! -f "$f" ]; then
    echo "No OAuth / browser URL captured yet."
    echo "When an agent or tool requests browser auth, the link will appear here."
    exit 0
  fi
  local url
  url=$(cat "$f")
  echo
  echo "=== Latest OAuth / Browser Link ==="
  echo "URL:"
  echo "  $url"
  echo
  if command -v qrencode >/dev/null 2>&1; then
    echo "Scan QR code with your phone camera to open link:"
    echo
    qrencode -t UTF8 "$url"
    echo
  fi
}

cmd_harness_list() {
  echo "DEFAULT_HARNESS=$DEFAULT_HARNESS"
  echo "Configured harnesses:"
  for k in "${!HARNESS_CMD[@]}"; do
    printf "  %-10s %s\n" "$k" "${HARNESS_CMD[$k]}"
  done
}

cmd_harness_add() {
  local name="${1:?usage: dev harness add <name> <launch command>}"
  shift || true
  local cmd="$*"
  [ -z "$cmd" ] && { echo "missing launch command"; exit 1; }
  grep -v "^${name}=" "$CONFIG" > "$CONFIG.tmp" 2>/dev/null || true
  mv "$CONFIG.tmp" "$CONFIG"
  echo "${name}=${cmd}" >> "$CONFIG"
  echo "Added harness '$name' -> '$cmd'"
}

cmd_ls_raw() {
  mkdir -p "$PROJECTS_DIR"
  local d
  for d in "$PROJECTS_DIR"/*; do
    [ -d "$d" ] || continue
    local b="${d##*/}"
    [ "$b" = ".persist" ] && continue
    echo "$b"
  done | sort
}

cmd_help() {
  cat <<'EOF'
persist-dev CLI

Usage: dev [command] [options]

Commands:
  ls                     List all projects and session status
  new <name> [url] [--harness H] Create a new project (clones git url if provided)
  attach <name>          Attach to a project tmux session (creates/starts if needed)
  run <name> [harness]   Launch or rerun harness in project session
  stop <name>            Stop project tmux session
  rm <name>              Stop session and prompt to remove project directory
  rename <old> <new>     Rename project directory and tmux session
  log <name> [-n lines]  Show log output for a project (tmux scrollback or log file)
  doctor                 Check health of environment, tmux, volumes, and harnesses
  ctx [show|edit|sync|pull] Manage shared agent context notes
  backup                 Backup /workspace to BACKUP_TARGET via rsync
  harness <list|add>     List or add custom harness launch configurations
  link                   Display latest captured OAuth/browser link (and QR code)
  menu                   Interactive fzf project selector
  help                   Show this help message
EOF
}

cmd_menu() {
  while true; do
    local raw_projects
    raw_projects=$(cmd_ls_raw)

    local items=("[+ Create new project]")
    if [ -n "$raw_projects" ]; then
      while IFS= read -r line; do
        [ -n "$line" ] && items+=("$line")
      done <<< "$raw_projects"
    fi

    local choice
    choice=$(printf '%s\n' "${items[@]}" | fzf --prompt="project> " --header="Select project or create new (ESC to exit)" || true)

    if [ -z "$choice" ]; then
      echo "(menu exited)"
      break
    fi

    if [ "$choice" = "[+ Create new project]" ]; then
      read -r -p "New project name: " new_name
      if [ -z "$new_name" ]; then
        echo "Cancelled."
        continue
      fi
      if ! valid_name "$new_name"; then
        continue
      fi
      read -r -p "Git repo URL (optional, press Enter to skip): " git_url
      echo "Available harnesses: ${!HARNESS_CMD[*]}"
      read -r -p "Harness [default: $DEFAULT_HARNESS]: " h_choice
      h_choice="${h_choice:-$DEFAULT_HARNESS}"

      cmd_new "$new_name" "$git_url" --harness "$h_choice"
      tmux attach -t "${TMUX_PREFIX}${new_name}" || true
    else
      valid_name "$choice" || continue
      cmd_attach "$choice" || true
    fi
  done
}

main() {
  load_config
  local cmd="${1:-menu}"; shift || true
  case "$cmd" in
    ls|list)        cmd_ls "$@" ;;
    new)            cmd_new "$@" ;;
    attach|a)       cmd_attach "$@" ;;
    run|launch)     cmd_run "$@" ;;
    stop|kill)      cmd_stop "$@" ;;
    rm|remove)      cmd_rm "$@" ;;
    rename|mv)      cmd_rename "$@" ;;
    log)            cmd_log "$@" ;;
    doctor|check)   cmd_doctor "$@" ;;
    ctx)            cmd_ctx "$@" ;;
    link|url|oauth) cmd_link "$@" ;;
    backup)         cmd_backup "$@" ;;
    harness)        sub="${1:-list}"; shift || true
                    case "$sub" in
                      list) cmd_harness_list "$@" ;;
                      add)  cmd_harness_add "$@" ;;
                      *)    echo "usage: dev harness <list|add>"; exit 1 ;;
                    esac ;;
    help|-h|--help) cmd_help "$@" ;;
    menu|"")        cmd_menu "$@" ;;
    *)              echo "dev: unknown command '$cmd'"; echo "usage: dev <ls|new|attach|run|stop|rm|rename|log|doctor|ctx|backup|harness|link|menu|help>"; exit 1 ;;
  esac
}
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
