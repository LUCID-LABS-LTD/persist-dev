#!/usr/bin/env bash
# /usr/bin/mosh-server wrapper: forces mosh-server to bind within
# the container's mapped UDP port range (default 60000:60050).
export LANG="${LANG:-C.UTF-8}"
export LC_ALL="${LC_ALL:-C.UTF-8}"

has_port=false
has_dashdash=false
dashdash_idx=-1

args=("$@")
for i in "${!args[@]}"; do
  arg="${args[$i]}"
  case "$arg" in
    -p*|--port|--port=*) has_port=true ;;
    --) has_dashdash=true; dashdash_idx=$i; break ;;
  esac
done

REAL_BIN="/usr/bin/mosh-server.real"
[ -f "$REAL_BIN" ] || REAL_BIN="/usr/bin/mosh-server"

if [ "$has_port" = "false" ]; then
  range="${MOSH_PORT_RANGE:-}"
  if [ -z "$range" ] && [ -f /etc/mosh_ports ]; then
    range=$(cat /etc/mosh_ports 2>/dev/null || echo "60000:60050")
  fi
  range="${range:-60000:60050}"
  range="${range//-/:}"

  if [ "$has_dashdash" = "true" ]; then
    before=("${args[@]:0:$dashdash_idx}")
    after=("${args[@]:$dashdash_idx}")
    exec "$REAL_BIN" "${before[@]}" -p "$range" "${after[@]}"
  else
    exec "$REAL_BIN" "${args[@]}" -p "$range"
  fi
else
  exec "$REAL_BIN" "${args[@]}"
fi
